<%- include('../partials/report-head', { title }) %>
<main class="report-shell">
  <header class="report-hero">
    <div>
      <p class="kicker">รายงานรายวัน</p>
      <h1>สรุปยอดขาย TikTok</h1>
      <p class="subtitle">วันที่ Settlement: <strong><%= periodLabel %></strong></p>
    </div>
    <nav class="hero-actions">
      <a href="/reports">กลับหน้ารายงาน</a>
      <a href="/reports/monthly?month=<%= periodLabel.slice(0, 7) %>">ดูรายเดือน</a>
      <button type="button" data-print-report>พิมพ์รายงาน</button>
    </nav>
  </header>

  <section class="stats-grid">
    <article class="stat-card">
      <span class="stat-label">จำนวนออเดอร์ที่รับรู้แล้ว</span>
      <strong><%= formatNumber(summary.sourceStats.settledOrders) %></strong>
    </article>
    <article class="stat-card">
      <span class="stat-label">ออเดอร์ที่แมปสินค้าได้</span>
      <strong><%= formatNumber(summary.sourceStats.matchedOrders) %></strong>
    </article>
    <article class="stat-card">
      <span class="stat-label">ความครอบคลุม</span>
      <strong><%= formatPercent(summary.sourceStats.coveragePercent) %></strong>
    </article>
    <article class="stat-card">
      <span class="stat-label">ยอด Settlement</span>
      <strong><%= formatMoney(summary.financeSummary.totalSettlementAmount) %></strong>
    </article>
  </section>

  <section class="panel">
    <h2>สรุปการเงิน</h2>
    <div class="key-value-grid">
      <div><span>รายได้รวม</span><strong><%= formatMoney(summary.financeSummary.totalRevenue) %></strong></div>
      <div><span>ยอด Settlement รวม</span><strong><%= formatMoney(summary.financeSummary.totalSettlementAmount) %></strong></div>
      <div><span>ค่าธรรมเนียมรวม</span><strong><%= formatMoney(summary.financeSummary.totalFees) %></strong></div>
      <div><span>ค่าส่งที่ผู้ขายรับผิดชอบ</span><strong><%= formatMoney(summary.financeSummary.sellerShippingFee) %></strong></div>
      <div><span>ค่า Affiliate Commission</span><strong><%= formatMoney(summary.financeSummary.affiliateCommission) %></strong></div>
      <div><span>ยอดถอนเงิน</span><strong><%= formatMoney(summary.withdrawalSummary.withdrawalAmount) %></strong></div>
    </div>
  </section>

  <section class="panel">
    <h2>เทียบยอด Revenue และยอดรับจริง</h2>
    <div class="key-value-grid">
      <div>
        <span>Revenue จากสินค้า</span>
        <strong><%= formatMoney(summary.reconciliation.revenue.productTotal) %></strong>
      </div>
      <div>
        <span>Revenue รวมจาก Income</span>
        <strong><%= formatMoney(summary.reconciliation.revenue.financeTotal) %></strong>
      </div>
      <div>
        <span>ส่วนต่าง Revenue</span>
        <strong><%= formatMoney(summary.reconciliation.revenue.difference) %></strong>
      </div>
      <div>
        <span>Orders subtotal (raw)</span>
        <strong><%= formatMoney(summary.reconciliation.rawOrders.productTotal) %></strong>
      </div>
      <div>
        <span>ส่วนต่าง Orders vs Income</span>
        <strong><%= formatMoney(summary.reconciliation.rawOrders.difference) %></strong>
      </div>
      <div>
        <span>ยอดรับจริงจากสินค้า</span>
        <strong><%= formatMoney(summary.reconciliation.settlement.productTotal) %></strong>
      </div>
      <div>
        <span>Settlement รวมจาก Income</span>
        <strong><%= formatMoney(summary.reconciliation.settlement.financeTotal) %></strong>
      </div>
      <div>
        <span>ส่วนต่างยอดรับจริง</span>
        <strong><%= formatMoney(summary.reconciliation.settlement.difference) %></strong>
      </div>
    </div>
    <p class="muted">
      Revenue หลักของรายงานมาจาก Income ที่ allocate ลงสินค้า ส่วน Orders subtotal ใช้ไว้ตรวจสอบความต่างกับไฟล์ Order
    </p>
  </section>

  <section class="panel">
    <div class="panel-head">
      <h2>สรุปตาม SKU</h2>
      <span><%= formatNumber(summary.skuSummary.length) %> รายการ</span>
    </div>
    <p class="muted">
      ใช้ Revenue base ตามระบบเดิม โดยราคาเฉลี่ย = ยอดรวมสินค้า / จำนวนขาย และคงยอดรับจริงไว้สำหรับเทียบ reconciliation
    </p>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Seller SKU</th>
            <th>ชื่อสินค้า</th>
            <th>จำนวนออเดอร์</th>
            <th>จำนวนขาย</th>
            <th>Multiple</th>
            <th>หน่วยฐาน</th>
            <th>ราคาเฉลี่ย</th>
            <th>ยอดรวม Revenue</th>
            <th>ยอดรับจริง</th>
          </tr>
        </thead>
        <tbody>
          <% if (summary.skuSummary.length === 0) { %>
            <tr><td colspan="9" class="empty-cell">ไม่มีข้อมูล</td></tr>
          <% } %>
          <% summary.skuSummary.forEach((row) => { %>
            <tr>
              <td><%= row.sellerSku || "-" %></td>
              <td><%= row.productName %></td>
              <td class="num"><%= formatNumber(row.ordersCount) %></td>
              <td class="num"><%= formatNumber(row.soldUnitsTikTok) %></td>
              <td class="num"><%= formatNumber(row.packMultiplier || 1) %></td>
              <td class="num"><%= formatNumber(row.equivalentBaseUnits) %></td>
              <td class="num"><%= row.soldUnitsTikTok > 0 ? formatMoney(row.allocatedRevenueAmount / row.soldUnitsTikTok) : "-" %></td>
              <td class="num"><%= formatMoney(row.allocatedRevenueAmount) %></td>
              <td class="num"><%= formatMoney(row.receivedSettlementAmount) %></td>
            </tr>
          <% }) %>
        </tbody>
        <tfoot>
          <tr>
            <th colspan="5">Grand Total</th>
            <th class="num"><%= formatNumber(summary.totals.skuSummary.equivalentBaseUnits) %></th>
            <th class="num">-</th>
            <th class="num"><%= formatMoney(summary.totals.skuSummary.amount) %></th>
            <th class="num"><%= formatMoney(summary.totals.settlement.skuSummary.amount) %></th>
          </tr>
        </tfoot>
      </table>
    </div>
  </section>

  <section class="panel">
    <h2>คำเตือน</h2>
    <% if (summary.warnings.length === 0) { %>
      <p class="muted">ไม่มีคำเตือน</p>
    <% } else { %>
      <ul class="warning-list">
        <% summary.warnings.forEach((warning) => { %>
          <li>
            <div class="warning-title">
              <strong><%= warning.type %></strong>
              <span><%= warning.message %></span>
            </div>
            <% if (warning.details && warning.details.rows.length > 0) { %>
              <div class="table-wrap compact-wrap warning-details">
                <table class="compact-table">
                  <thead>
                    <tr>
                      <% warning.columns.forEach((column) => { %>
                        <th><%= column.label %></th>
                      <% }) %>
                    </tr>
                  </thead>
                  <tbody>
                    <% warning.details.rows.forEach((detail) => { %>
                      <tr>
                        <% warning.columns.forEach((column) => { %>
                          <% const rawValue = detail[column.key]; %>
                          <td class="<%= column.format === 'money' || column.format === 'number' ? 'num' : '' %>">
                            <% if (column.format === "money") { %>
                              <%= formatMoney(rawValue) %>
                            <% } else if (column.format === "number") { %>
                              <%= formatNumber(rawValue) %>
                            <% } else { %>
                              <%= rawValue || "-" %>
                            <% } %>
                          </td>
                        <% }) %>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
              <% if (warning.details.extraCount > 0) { %>
                <p class="warning-meta">แสดง <%= formatNumber(warning.details.rows.length) %> จากทั้งหมด <%= formatNumber(warning.details.totalCount) %> รายการ</p>
              <% } %>
            <% } %>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </section>
</main>
<%- include('../partials/report-foot') %>
